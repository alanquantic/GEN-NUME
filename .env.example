# Copia este archivo a .env para desarrollo local.
# En Railway se configuran como Variables del servicio (NO subir el .env real).

# Secreto compartido con la tienda Next.js para firmar el webhook (HMAC-SHA256).
WEBHOOK_SECRET=cambia-esto-por-un-secreto-largo-aleatorio
REQUIRE_SIGNATURE=true

# Almacenamiento persistente. En Railway = punto de montaje del Volume.
STORAGE_DIR=data

# URL pública base para construir los enlaces de descarga de PDFs.
PUBLIC_BASE_URL=http://localhost:8000

# Rutas de assets y contenido (relativas a la raíz del proyecto).
ASSETS_DIR=assets
CONTENT_DIR=content

ENVIRONMENT=development
